# Environment Variables for Terminal BTC Backend
# Copy file ini menjadi .env dan isi dengan nilai yang sesuai

# ====================================
# SERVER
# ====================================
PORT=3001
NODE_ENV=development

# ====================================
# JWT (Authentication)
# ====================================
# Ganti dengan string random yang panjang dan aman
# Contoh: bisa generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ganti_dengan_string_random_aman_minimal_32_karakter

# ====================================
# WEBHOOK SECRET
# ====================================
# Token rahasia yang harus sama dengan yang diset di TradingView alert webhook URL
# Contoh: WEBHOOK_SECRET=terminalbtc_secret_2024
WEBHOOK_SECRET=ganti_dengan_token_rahasia_webhook

# ====================================
# TELEGRAM BOT (Notifikasi)
# ====================================
# Cara mendapatkan:
# 1. Buka Telegram, cari @BotFather
# 2. Ketik /newbot → ikuti instruksi → copy token yang diberikan
# Contoh: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=isi_dengan_token_bot_telegram_kamu

# Chat ID Telegram kamu (akun pribadi yang akan menerima notifikasi)
# Cara mendapatkan:
# 1. Buka Telegram, cari @userinfobot
# 2. Start bot tersebut, dan ia akan memberikan Chat ID kamu
# Contoh: 123456789
TELEGRAM_CHAT_ID=isi_dengan_chat_id_telegram_kamu

# ====================================
# FRONTEND URL (untuk CORS)
# ====================================
FRONTEND_URL=http://localhost:5173
